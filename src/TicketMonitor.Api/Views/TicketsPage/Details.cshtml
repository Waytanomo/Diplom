@{
    ViewData["Title"] = "Ticket";
}

<div id="loadingWrap" class="loading-overlay"><div class="tm-spinner"></div></div>
<div id="content" style="display:none">

    <div class="page-header">
        <div>
            <div style="display:flex;align-items:center;gap:10px;margin-bottom:8px">
                <a asp-controller="TicketsPage" asp-action="Index"
                   class="tm-btn tm-btn-ghost tm-btn-sm" style="padding:4px 10px"
                   data-i18n="ticket.back">← Back</a>
                <span class="ticket-id" id="ticketId"></span>
            </div>
            <h1 class="page-title" id="ticketTitle" style="font-size:1.5rem"></h1>
            <div class="detail-meta-row" id="metaBadges"></div>
        </div>
        <div style="display:flex;gap:8px" id="actionBtns"></div>
    </div>

    <div class="ticket-detail-grid">
        <div>
            <div class="tm-card" style="margin-bottom:24px">
                <div class="tm-card-header">
                    <span style="font-size:0.75rem;font-weight:700;text-transform:uppercase;
                    letter-spacing:0.08em;color:var(--text-muted)"
                          data-i18n="ticket.description">Description</span>
                </div>
                <div class="tm-card-body">
                    <div class="ticket-body" id="ticketDesc"></div>
                </div>
            </div>

            <div class="tm-card">
                <div class="tm-card-header">
                    <div class="comments-title">
                        <span data-i18n="comments.title">Comments</span>
                        <span class="comment-count" id="commentCount">0</span>
                    </div>
                </div>
                <div class="tm-card-body">
                    <div id="commentList" class="comment-list"></div>
                    <div id="noComments" class="empty-state" style="padding:32px;display:none">
                        <div class="empty-icon">💬</div>
                        <div class="empty-text" data-i18n="comments.empty">No comments yet</div>
                    </div>
                    <div class="comment-form" style="margin-top:20px">
                        <textarea class="tm-textarea" id="commentText"
                                  data-i18n-placeholder="comments.placeholder"
                                  placeholder="Write a comment…"
                                  rows="3" style="min-height:80px"></textarea>
                        <div style="display:flex;justify-content:space-between;align-items:center">
                            <span style="font-size:0.75rem;color:var(--text-muted)"
                                  data-i18n="comments.hint">Ctrl+Enter to submit</span>
                            <button class="tm-btn tm-btn-primary tm-btn-sm"
                                    id="submitComment" data-i18n="comments.post">
                                Post Comment
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div>
            <div class="sidebar-section">
                <div class="sidebar-section-title" data-i18n="ticket.details">Details</div>
                <div id="ticketMeta"></div>
            </div>

            <div class="sidebar-section" id="statusSection" style="display:none">
                <div class="sidebar-section-title" data-i18n="ticket.change_status">Change Status</div>
                <select class="tm-select" id="newStatus" style="margin-bottom:10px">
                    <option value="0" data-i18n="status.Open">Open</option>
                    <option value="1" data-i18n="status.InProgress">In Progress</option>
                    <option value="2" data-i18n="status.Resolved">Resolved</option>
                    <option value="3" data-i18n="status.Closed">Closed</option>
                </select>
                <button class="tm-btn tm-btn-secondary tm-btn-sm" id="changeStatusBtn"
                        style="width:100%;justify-content:center"
                        data-i18n="ticket.update_status">
                    Update Status
                </button>
            </div>

            <div class="sidebar-section" id="assignSection" style="display:none">
                <div class="sidebar-section-title" data-i18n="ticket.assign">Assign Ticket</div>
                <select class="tm-select" id="assigneeSelect" style="margin-bottom:10px">
                    <option value="" data-i18n="common.unassigned">Unassigned</option>
                </select>
                <button class="tm-btn tm-btn-secondary tm-btn-sm" id="assignBtn"
                        style="width:100%;justify-content:center"
                        data-i18n="ticket.assign_btn">
                    Assign
                </button>
            </div>

            <div class="sidebar-section">
                <div class="sidebar-section-title" data-i18n="ticket.history">Status History</div>
                <div id="statusLogContainer" class="status-log">
                    <div style="color:var(--text-muted);font-size:0.8rem"
                         data-i18n="ticket.no_history">
                        No history yet
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="deleteModal" class="tm-modal-backdrop" style="display:none">
    <div class="tm-modal">
        <div class="modal-title" data-i18n="ticket.delete_confirm">Delete Ticket?</div>
        <p style="color:var(--text-secondary);font-size:0.9rem"
           data-i18n="ticket.delete_warning">This action cannot be undone.</p>
        <div class="modal-footer">
            <button class="tm-btn tm-btn-secondary"
                    onclick="document.getElementById('deleteModal').style.display='none'"
                    data-i18n="ticket.cancel">
                Cancel
            </button>
            <button class="tm-btn tm-btn-danger" id="confirmDelete"
                    data-i18n="ticket.delete">
                Delete
            </button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            requireAuth();

            var ticketId   = parseInt(location.pathname.split('/').pop());
            if (!ticketId) return;

            var canManage = Auth.hasAnyRole('Manager', 'Administrator');
            var currentTicket = null;

            function loadTicket() {
                return API.get('/api/tickets/' + ticketId)
                    .then(function (res) {
                        if (res.status === 404) {
                            document.getElementById('loadingWrap').innerHTML =
                                '<div class="empty-state"><div class="empty-icon">404</div>' +
                                '<div class="empty-text">Ticket not found</div></div>';
                            return null;
                        }
                        return res.json();
                    })
                    .then(function (ticket) {
                        if (ticket) { currentTicket = ticket; renderTicket(ticket); }
                    })
                    .catch(function () { Notifications.error(t('common.error')); });
            }

            function loadComments() {
                return API.get('/api/tickets/' + ticketId + '/comments')
                    .then(function (res) { return res.json(); })
                    .then(function (comments) { renderComments(comments); })
                    .catch(function () {});
            }

            function loadUsers() {
                if (!canManage) return;
                API.get('/api/users')
                    .then(function (res) { return res.ok ? res.json() : []; })
                    .then(function (users) {
                        var sel = document.getElementById('assigneeSelect');
                        sel.innerHTML = '<option value="">' + t('common.unassigned') + '</option>' +
                            users.map(function (u) {
                                return '<option value="' + u.id + '">' + Helpers.escapeHtml(u.userName) + '</option>';
                            }).join('');
                        if (currentTicket && currentTicket.assignedToId)
                            sel.value = currentTicket.assignedToId;
                    })
                    .catch(function () {});
            }

            function renderTicket(ticket) {
                document.getElementById('loadingWrap').style.display = 'none';
                document.getElementById('content').style.display    = '';
                document.getElementById('ticketId').textContent     = '#' + ticket.id;
                document.getElementById('ticketTitle').textContent  = ticket.title;
                document.getElementById('ticketDesc').textContent   = ticket.description;
                document.getElementById('metaBadges').innerHTML =
                    Helpers.statusBadge(ticket.status) + ' ' + Helpers.priorityBadge(ticket.priority);

                document.getElementById('ticketMeta').innerHTML =
                    '<div class="meta-row">' +
                        '<span class="meta-key">'  + t('ticket.created_by') + '</span>' +
                        '<span class="meta-val">'  + Helpers.escapeHtml(ticket.createdByName) + '</span>' +
                    '</div>' +
                    '<div class="meta-row">' +
                        '<span class="meta-key">'  + t('ticket.assigned_to') + '</span>' +
                        '<span class="meta-val">'  + (ticket.assignedToName
                            ? Helpers.escapeHtml(ticket.assignedToName)
                            : '<span style="color:var(--text-muted)">' + t('common.unassigned') + '</span>') + '</span>' +
                    '</div>' +
                    '<div class="meta-row">' +
                        '<span class="meta-key">'  + t('ticket.created_at') + '</span>' +
                        '<span class="meta-val">'  + Helpers.formatDateTime(ticket.createdAt) + '</span>' +
                    '</div>' +
                    (ticket.closedAt
                        ? '<div class="meta-row">' +
                            '<span class="meta-key">'  + t('ticket.closed_at') + '</span>' +
                            '<span class="meta-val">'  + Helpers.formatDateTime(ticket.closedAt) + '</span>' +
                          '</div>'
                        : '');

                var actionBtns = document.getElementById('actionBtns');
                actionBtns.innerHTML = '';
                if (canManage) {
                    var btn = document.createElement('button');
                    btn.className   = 'tm-btn tm-btn-danger tm-btn-sm';
                    btn.textContent = t('ticket.delete');
                    btn.addEventListener('click', function () {
                        document.getElementById('deleteModal').style.display = 'flex';
                    });
                    actionBtns.appendChild(btn);
                }

                if (canManage) {
                    document.getElementById('statusSection').style.display = '';
                    document.getElementById('assignSection').style.display = '';
                    var statusMap = { Open: 0, InProgress: 1, Resolved: 2, Closed: 3 };
                    document.getElementById('newStatus').value = statusMap[ticket.status] || 0;
                    loadUsers();
                }
            }

            function renderComments(comments) {
                var list      = document.getElementById('commentList');
                var noComments = document.getElementById('noComments');
                document.getElementById('commentCount').textContent = comments.length;
                if (!comments.length) { list.innerHTML = ''; noComments.style.display = ''; return; }
                noComments.style.display = 'none';
                list.innerHTML = comments.map(function (c) {
                    return '<div class="comment-item">' +
                        '<div class="comment-header">' +
                            '<div class="comment-avatar">' +
                                Helpers.escapeHtml((c.authorName[0] || '?').toUpperCase()) +
                            '</div>' +
                            '<span class="comment-author">' + Helpers.escapeHtml(c.authorName) + '</span>' +
                            '<span class="comment-time">' + Helpers.timeAgo(c.createdAt) + '</span>' +
                        '</div>' +
                        '<div class="comment-text">' + Helpers.escapeHtml(c.text) + '</div>' +
                        '</div>';
                }).join('');
            }

            document.getElementById('changeStatusBtn').addEventListener('click', function () {
                var newStatus = parseInt(document.getElementById('newStatus').value);
                var btn = this; btn.disabled = true; btn.textContent = t('common.loading');
                API.put('/api/tickets/' + ticketId + '/status', { newStatus: newStatus })
                    .then(function (res) {
                        if (!res.ok) throw new Error();
                        Notifications.success('✓');
                        return loadTicket();
                    })
                    .catch(function () { Notifications.error(t('common.error')); })
                    .finally(function () { btn.disabled = false; btn.textContent = t('ticket.update_status'); });
            });

            document.getElementById('assignBtn').addEventListener('click', function () {
                var assigneeId = document.getElementById('assigneeSelect').value || null;
                var btn = this; btn.disabled = true; btn.textContent = t('common.loading');
                API.put('/api/tickets/' + ticketId + '/assign', { assigneeId: assigneeId })
                    .then(function (res) {
                        if (!res.ok) throw new Error();
                        Notifications.success('✓');
                        return loadTicket();
                    })
                    .catch(function () { Notifications.error(t('common.error')); })
                    .finally(function () { btn.disabled = false; btn.textContent = t('ticket.assign_btn'); });
            });

            document.getElementById('submitComment').addEventListener('click', function () {
                var text = document.getElementById('commentText').value.trim();
                if (!text) return;
                var btn = this; btn.disabled = true; btn.textContent = t('comments.posting');
                API.post('/api/tickets/' + ticketId + '/comments', { text: text })
                    .then(function (res) {
                        if (!res.ok) throw new Error();
                        document.getElementById('commentText').value = '';
                        return loadComments();
                    })
                    .catch(function () { Notifications.error(t('common.error')); })
                    .finally(function () { btn.disabled = false; btn.textContent = t('comments.post'); });
            });

            document.getElementById('commentText').addEventListener('keydown', function (e) {
                if (e.key === 'Enter' && (e.ctrlKey || e.metaKey))
                    document.getElementById('submitComment').click();
            });

            document.getElementById('confirmDelete').addEventListener('click', function () {
                document.getElementById('deleteModal').style.display = 'none';
                API.delete('/api/tickets/' + ticketId)
                    .then(function (res) {
                        if (!res.ok) throw new Error();
                        Notifications.success('✓');
                        setTimeout(function () { window.location.href = '/TicketsPage'; }, 800);
                    })
                    .catch(function () { Notifications.error(t('common.error')); });
            });

            document.addEventListener('tm:statusChanged',  function (e) { if (e.detail.ticketId == ticketId) loadTicket(); });
            document.addEventListener('tm:commentAdded',   function ()  { loadComments(); });
            document.addEventListener('tm:ticketAssigned', function (e) { if (e.detail.ticketId == ticketId) loadTicket(); });
            document.addEventListener('tm:langChanged',    function ()  {
                I18n.applyToPage();
                if (currentTicket) renderTicket(currentTicket);
            });

            loadTicket().then(function () { return loadComments(); });
            setTimeout(function () { TM_SignalR.joinTicket(ticketId); }, 1000);
        });
    </script>
}