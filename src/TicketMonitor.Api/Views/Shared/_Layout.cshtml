<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TicketMonitor</title>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <nav class="tm-nav">
        <div class="container">
            <a class="nav-brand" asp-controller="HomePage" asp-action="Index">
                <span class="nav-brand-dot"></span>
                TicketMonitor
            </a>
            <ul class="nav-links" id="nav-links">
                <li>
                    <a asp-controller="TicketsPage" asp-action="Index" data-i18n="nav.tickets">Tickets</a>
                </li>
                <li id="nav-dashboard" style="display:none">
                    <a asp-controller="DashboardPage" asp-action="Index" data-i18n="nav.dashboard">Dashboard</a>
                </li>
                <li id="nav-admin" style="display:none">
                    <a asp-controller="AdminPage" asp-action="Users" data-i18n="nav.admin">Admin</a>
                </li>
                <li>
                    <div id="lang-switcher"></div>
                </li>
                <li id="nav-login">
                    <a asp-controller="AuthPage" asp-action="Login" data-i18n="nav.login">Login</a>
                </li>
                <!-- Выпадающее меню пользователя (logout внутри) -->
                <li id="nav-user-menu" style="display:none;position:relative">
                    <button class="nav-user-btn" id="nav-user-btn" type="button">
                        <span class="nav-user-avatar" id="nav-user-avatar"></span>
                        <span id="nav-username"></span>
                        <span class="nav-user-caret">▾</span>
                    </button>
                    <div class="nav-dropdown" id="nav-dropdown">
                        <div class="nav-dropdown-header">
                            <div class="nav-dropdown-username" id="nav-dropdown-username"></div>
                            <div class="nav-dropdown-role" id="nav-dropdown-role"></div>
                        </div>
                        <div class="nav-dropdown-divider"></div>
                        <button class="nav-dropdown-item nav-dropdown-item--danger"
                                id="nav-logout" type="button">
                            <span>⎋</span>
                            <span data-i18n="nav.logout">Logout</span>
                        </button>
                    </div>
                </li>
            </ul>
        </div>
    </nav>

    <main class="tm-main">
        @RenderBody()
    </main>

    <script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@@8.0.7/dist/browser/signalr.min.js"></script>
    <script src="~/js/i18n.js" asp-append-version="true"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>