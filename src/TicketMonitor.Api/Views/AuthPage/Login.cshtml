@{
    ViewData["Title"] = "Login";
}

<div class="auth-wrap">
    <div class="auth-card">
        <h1 class="auth-title" data-i18n="login.title">Welcome back</h1>
        <p class="auth-subtitle" data-i18n="login.subtitle">Sign in to your TicketMonitor account</p>

        <div id="errorMsg" class="tm-alert tm-alert-danger"></div>

        <div class="tm-form-group">
            <label class="tm-label" for="username" data-i18n="login.username">Username</label>
            <input type="text" class="tm-input" id="username"
                   data-i18n-placeholder="login.username"
                   placeholder="Username"
                   autocomplete="username" />
        </div>

        <div class="tm-form-group">
            <label class="tm-label" for="password" data-i18n="login.password">Password</label>
            <input type="password" class="tm-input" id="password"
                   placeholder="••••••••"
                   autocomplete="current-password" />
        </div>

        <button class="tm-btn tm-btn-primary" id="loginBtn"
                style="width:100%;justify-content:center;margin-top:4px"
                data-i18n="login.submit">
            Sign In
        </button>

        @* Публичная регистрация отключена. Пользователей создаёт администратор. *@
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            if (Auth.isLoggedIn()) { window.location.href = '/TicketsPage'; return; }

            var btn        = document.getElementById('loginBtn');
            var errorMsg   = document.getElementById('errorMsg');
            var usernameEl = document.getElementById('username');
            var passwordEl = document.getElementById('password');

            function doLogin() {
                var username = usernameEl.value.trim();
                var password = passwordEl.value;
                errorMsg.classList.remove('show');

                if (!username || !password) {
                    errorMsg.textContent = t('login.error_empty');
                    errorMsg.classList.add('show');
                    return;
                }

                btn.disabled = true;
                btn.textContent = t('login.signing');

                fetch('/api/auth/login', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ username: username, password: password })
                })
                .then(function (res) {
                    if (!res.ok) return res.json().then(function (d) { throw new Error(d.message || t('login.error_empty')); });
                    return res.json();
                })
                .then(function (data) {
                    Auth.setSession(data.token, data.user);
                    window.location.href = '/TicketsPage';
                })
                .catch(function (err) {
                    errorMsg.textContent = err.message;
                    errorMsg.classList.add('show');
                    btn.disabled = false;
                    btn.textContent = t('login.submit');
                });
            }

            btn.addEventListener('click', doLogin);
            usernameEl.addEventListener('keydown', function (e) { if (e.key === 'Enter') doLogin(); });
            passwordEl.addEventListener('keydown', function (e) { if (e.key === 'Enter') doLogin(); });

            document.addEventListener('tm:langChanged', function () {
                if (!btn.disabled) btn.textContent = t('login.submit');
            });
        });
    </script>
}