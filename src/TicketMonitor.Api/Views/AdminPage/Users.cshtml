@{
    ViewData["Title"] = "User Management";
}

<div class="page-header">
    <div>
        <h1 class="page-title">User Management</h1>
        <p class="page-subtitle">Manage users and roles</p>
    </div>
    <a asp-controller="AuthPage" asp-action="Register" class="tm-btn tm-btn-primary">+ Add User</a>
</div>

<div class="tm-card">
    <div class="tm-table-wrap">
        <table class="tm-table">
            <thead>
                <tr>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody id="usersBody">
                <tr><td colspan="4"><div class="loading-overlay"><div class="tm-spinner"></div></div></td></tr>
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', async () => {
    requireAuth(['Administrator']);

    const roles = ['Administrator', 'Manager', 'Executor', 'Client'];
    const currentUser = Auth.getUser();

    async function loadUsers() {
        try {
            const res = await API.get('/api/users');
            if (!res.ok) throw new Error();
            const users = await res.json();
            renderUsers(users);
        } catch {
            Notifications.error('Failed to load users');
        }
    }

    function renderUsers(users) {
        const tbody = document.getElementById('usersBody');
        if (!users.length) {
            tbody.innerHTML = '<tr><td colspan="4"><div class="empty-state">No users found</div></td></tr>';
            return;
        }

        tbody.innerHTML = users.map(u => {
            const isSelf = u.id === currentUser?.id;
            const roleLabel = u.roles?.[0] || 'None';
            const roleColors = { Administrator: '#ef4444', Manager: '#f59e0b', Executor: '#6366f1', Client: '#10b981' };

            return `
                <tr>
                    <td>
                        <div style="display:flex;align-items:center;gap:10px">
                            <div style="width:32px;height:32px;border-radius:50%;background:var(--bg-elevated);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;font-size:0.75rem;font-weight:700;color:var(--accent)">
                                ${Helpers.escapeHtml(u.userName[0]?.toUpperCase() || '?')}
                            </div>
                            <span style="font-weight:500">${Helpers.escapeHtml(u.userName)}</span>
                            ${isSelf ? '<span style="font-size:0.7rem;color:var(--text-muted);background:var(--bg-elevated);padding:2px 8px;border-radius:10px;border:1px solid var(--border)">you</span>' : ''}
                        </div>
                    </td>
                    <td style="color:var(--text-secondary);font-size:0.875rem">${Helpers.escapeHtml(u.email)}</td>
                    <td>
                        <select class="role-select" onchange="changeRole('${u.id}', this.value)" ${isSelf ? 'disabled' : ''}>
                            ${roles.map(r => `<option value="${r}" ${r === roleLabel ? 'selected' : ''} style="color:${roleColors[r] || 'inherit'}">${r}</option>`).join('')}
                        </select>
                    </td>
                    <td>
                        ${!isSelf ? `<button class="tm-btn tm-btn-danger tm-btn-sm" onclick="deleteUser('${u.id}', '${Helpers.escapeHtml(u.userName)}')">Delete</button>` : '—'}
                    </td>
                </tr>
            `;
        }).join('');
    }

    window.changeRole = async (userId, role) => {
        try {
            const res = await API.put(`/api/users/${userId}/role`, { role });
            if (!res.ok) throw new Error();
            Notifications.success(`Role updated to ${role}`);
        } catch {
            Notifications.error('Failed to update role');
            loadUsers();
        }
    };

    window.deleteUser = async (userId, username) => {
        if (!confirm(`Delete user "${username}"? This cannot be undone.`)) return;
        try {
            const res = await API.delete(`/api/users/${userId}`);
            if (!res.ok) throw new Error();
            Notifications.success(`User deleted`);
            loadUsers();
        } catch {
            Notifications.error('Failed to delete user');
        }
    };

    loadUsers();
});
</script>
}
