@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1 class="page-title">Dashboard</h1>
        <p class="page-subtitle">Real-time ticket analytics</p>
    </div>
    <button class="tm-btn tm-btn-secondary tm-btn-sm" id="refreshBtn">↻ Refresh</button>
</div>

<div class="stat-grid" id="statGrid">
    <div class="stat-card accent">
        <div class="stat-label">Total Tickets</div>
        <div class="stat-value" id="statTotal">—</div>
    </div>
    <div class="stat-card blue">
        <div class="stat-label">Open</div>
        <div class="stat-value" id="statOpen">—</div>
    </div>
    <div class="stat-card red">
        <div class="stat-label">In Progress</div>
        <div class="stat-value" id="statInProgress">—</div>
    </div>
    <div class="stat-card green">
        <div class="stat-label">Resolved</div>
        <div class="stat-value" id="statResolved">—</div>
    </div>
    <div class="stat-card accent" style="--accent:#6366f1">
        <div class="stat-label">Avg Resolution</div>
        <div class="stat-value" id="statAvg" style="font-size:1.4rem">—</div>
        <div style="font-size:0.75rem;color:var(--text-muted);margin-top:4px">hours</div>
    </div>
</div>

<div class="charts-grid">
    <!-- Status donut -->
    <div class="chart-card">
        <div class="chart-title">By Status</div>
        <div class="donut-wrap">
            <canvas id="statusChart" width="160" height="160" style="flex-shrink:0"></canvas>
            <div class="donut-legend" id="statusLegend"></div>
        </div>
    </div>

    <!-- Priority donut -->
    <div class="chart-card">
        <div class="chart-title">By Priority</div>
        <div class="donut-wrap">
            <canvas id="priorityChart" width="160" height="160" style="flex-shrink:0"></canvas>
            <div class="donut-legend" id="priorityLegend"></div>
        </div>
    </div>

    <!-- Assignee bar -->
    <div class="chart-card" style="grid-column:1/-1">
        <div class="chart-title">By Assignee</div>
        <div class="bar-chart" id="assigneeChart">
            <div style="color:var(--text-muted);font-size:0.85rem">No data</div>
        </div>
    </div>
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', () => {
    requireAuth(['Administrator', 'Manager']);

    const STATUS_COLORS  = { Open: '#6366f1', InProgress: '#f59e0b', Resolved: '#10b981', Closed: '#4b5563' };
    const PRIORITY_COLORS = { Low: '#6ee7b7', Medium: '#a5b4fc', High: '#fb923c', Critical: '#f87171' };

    function drawDonut(canvasId, data, colors) {
        const canvas = document.getElementById(canvasId);
        const ctx = canvas.getContext('2d');
        const W = canvas.width, H = canvas.height;
        const cx = W/2, cy = H/2, r = Math.min(W,H)/2 - 8;
        const inner = r * 0.55;

        const total = Object.values(data).reduce((a,b) => a+b, 0);
        ctx.clearRect(0, 0, W, H);

        if (total === 0) {
            ctx.fillStyle = '#1a2234';
            ctx.beginPath(); ctx.arc(cx, cy, r, 0, Math.PI*2); ctx.fill();
            ctx.fillStyle = '#0a0f1a';
            ctx.beginPath(); ctx.arc(cx, cy, inner, 0, Math.PI*2); ctx.fill();
            return;
        }

        let angle = -Math.PI / 2;
        const gap = 0.04;

        Object.entries(data).forEach(([key, val]) => {
            const slice = (val / total) * (Math.PI * 2) - gap;
            ctx.beginPath();
            ctx.moveTo(cx, cy);
            ctx.arc(cx, cy, r, angle + gap/2, angle + slice + gap/2);
            ctx.closePath();
            ctx.fillStyle = colors[key] || '#4a5e82';
            ctx.fill();
            angle += slice + gap;
        });

        // Center hole
        ctx.beginPath();
        ctx.arc(cx, cy, inner, 0, Math.PI*2);
        ctx.fillStyle = '#111827';
        ctx.fill();

        // Center text
        ctx.fillStyle = '#e8edf5';
        ctx.font = `bold 22px 'DM Sans'`;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(total, cx, cy);
    }

    function renderLegend(containerId, data, colors) {
        const el = document.getElementById(containerId);
        el.innerHTML = Object.entries(data).map(([k, v]) => `
            <div class="legend-item">
                <div class="legend-dot" style="background:${colors[k] || '#4a5e82'}"></div>
                <span>${k}</span>
                <span class="legend-val">${v}</span>
            </div>
        `).join('');
    }

    function renderAssigneeBar(data) {
        const el = document.getElementById('assigneeChart');
        const entries = Object.entries(data).sort((a,b) => b[1]-a[1]);
        if (entries.length === 0) {
            el.innerHTML = '<div style="color:var(--text-muted);font-size:0.85rem">No assigned tickets</div>';
            return;
        }
        const max = Math.max(...entries.map(e => e[1]));
        const barColors = ['#f59e0b','#6366f1','#10b981','#ef4444','#f97316','#8b5cf6'];
        el.innerHTML = entries.slice(0, 10).map(([name, count], i) => `
            <div class="bar-row">
                <div class="bar-label">${Helpers.escapeHtml(name)}</div>
                <div class="bar-track">
                    <div class="bar-fill" style="width:${(count/max)*100}%;background:${barColors[i%barColors.length]}"></div>
                </div>
                <div class="bar-count">${count}</div>
            </div>
        `).join('');
    }

    function animateCount(el, target) {
        const start = 0;
        const duration = 600;
        const startTime = performance.now();
        const isDecimal = String(target).includes('.');
        function update(now) {
            const p = Math.min((now - startTime) / duration, 1);
            const ease = 1 - Math.pow(1 - p, 3);
            const val = start + (target - start) * ease;
            el.textContent = isDecimal ? val.toFixed(1) : Math.round(val);
            if (p < 1) requestAnimationFrame(update);
        }
        requestAnimationFrame(update);
    }

    async function loadStats() {
        try {
            const res = await API.get('/api/tickets/stats');
            if (!res.ok) throw new Error('Failed to load stats');
            const stats = await res.json();

            animateCount(document.getElementById('statTotal'), stats.total);
            animateCount(document.getElementById('statOpen'), stats.byStatus?.Open || 0);
            animateCount(document.getElementById('statInProgress'), stats.byStatus?.InProgress || 0);
            animateCount(document.getElementById('statResolved'), (stats.byStatus?.Resolved || 0) + (stats.byStatus?.Closed || 0));
            animateCount(document.getElementById('statAvg'), stats.avgResolutionHours);

            drawDonut('statusChart', stats.byStatus || {}, STATUS_COLORS);
            renderLegend('statusLegend', stats.byStatus || {}, STATUS_COLORS);

            drawDonut('priorityChart', stats.byPriority || {}, PRIORITY_COLORS);
            renderLegend('priorityLegend', stats.byPriority || {}, PRIORITY_COLORS);

            renderAssigneeBar(stats.byAssignee || {});
        } catch (err) {
            Notifications.error('Failed to load statistics: ' + err.message);
        }
    }

    document.getElementById('refreshBtn').addEventListener('click', loadStats);

    // Real-time refresh on ticket events
    document.addEventListener('tm:ticketCreated', () => loadStats());
    document.addEventListener('tm:ticketUpdated', () => loadStats());
    document.addEventListener('tm:statusChanged', () => loadStats());

    loadStats();
});
</script>
}
