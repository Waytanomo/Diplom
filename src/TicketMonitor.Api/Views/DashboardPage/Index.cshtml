@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header">
    <div>
        <h1 class="page-title" data-i18n="dashboard.title">Dashboard</h1>
        <p class="page-subtitle" data-i18n="dashboard.subtitle">Real-time ticket analytics</p>
    </div>
    <button class="tm-btn tm-btn-secondary tm-btn-sm" id="refreshBtn"
            data-i18n="dashboard.refresh">
        ↻ Refresh
    </button>
</div>

<div class="stat-grid">
    <div class="stat-card accent">
        <div class="stat-label" data-i18n="dashboard.total">Total Tickets</div>
        <div class="stat-value" id="statTotal">—</div>
    </div>
    <div class="stat-card blue">
        <div class="stat-label" data-i18n="dashboard.open">Open</div>
        <div class="stat-value" id="statOpen">—</div>
    </div>
    <div class="stat-card red">
        <div class="stat-label" data-i18n="dashboard.inprogress">In Progress</div>
        <div class="stat-value" id="statInProgress">—</div>
    </div>
    <div class="stat-card green">
        <div class="stat-label" data-i18n="dashboard.resolved">Resolved</div>
        <div class="stat-value" id="statResolved">—</div>
    </div>
    <div class="stat-card" style="border-color:var(--border)">
        <div class="stat-label" data-i18n="dashboard.avg">Avg Resolution</div>
        <div class="stat-value" id="statAvg" style="color:#6366f1;font-size:1.4rem">—</div>
        <div style="font-size:0.75rem;color:var(--text-muted);margin-top:4px"
             data-i18n="dashboard.hours">
            hours
        </div>
    </div>
</div>

<div class="charts-grid">
    <div class="chart-card">
        <div class="chart-title" data-i18n="dashboard.by_status">By Status</div>
        <div class="donut-wrap">
            <canvas id="statusChart" width="160" height="160" style="flex-shrink:0"></canvas>
            <div class="donut-legend" id="statusLegend"></div>
        </div>
    </div>
    <div class="chart-card">
        <div class="chart-title" data-i18n="dashboard.by_priority">By Priority</div>
        <div class="donut-wrap">
            <canvas id="priorityChart" width="160" height="160" style="flex-shrink:0"></canvas>
            <div class="donut-legend" id="priorityLegend"></div>
        </div>
    </div>
    <div class="chart-card" style="grid-column:1/-1">
        <div class="chart-title" data-i18n="dashboard.by_assignee">By Assignee</div>
        <div class="bar-chart" id="assigneeChart">
            <div style="color:var(--text-muted);font-size:0.85rem"
                 data-i18n="dashboard.no_data">
                No assigned tickets
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener('DOMContentLoaded', function () {
            requireAuth(['Administrator', 'Manager']);

            var STATUS_COLORS   = { Open:'#6366f1', InProgress:'#f59e0b', Resolved:'#10b981', Closed:'#4b5563' };
            var PRIORITY_COLORS = { Low:'#6ee7b7', Medium:'#a5b4fc', High:'#fb923c', Critical:'#f87171' };

            function drawDonut(canvasId, data, colors) {
                var canvas = document.getElementById(canvasId);
                if (!canvas) return;
                var ctx = canvas.getContext('2d');
                var W = canvas.width, H = canvas.height;
                var cx = W/2, cy = H/2, r = Math.min(W,H)/2 - 8, inner = r * 0.55;
                var total = Object.values(data).reduce(function (a,b) { return a+b; }, 0);
                ctx.clearRect(0, 0, W, H);
                if (total === 0) {
                    ctx.fillStyle = '#1a2234'; ctx.beginPath(); ctx.arc(cx,cy,r,0,Math.PI*2); ctx.fill();
                    ctx.fillStyle = '#111827'; ctx.beginPath(); ctx.arc(cx,cy,inner,0,Math.PI*2); ctx.fill();
                    return;
                }
                var angle = -Math.PI / 2, gap = 0.04;
                Object.entries(data).forEach(function (entry) {
                    var key = entry[0], val = entry[1];
                    var slice = (val / total) * (Math.PI * 2) - gap;
                    ctx.beginPath(); ctx.moveTo(cx,cy);
                    ctx.arc(cx, cy, r, angle + gap/2, angle + slice + gap/2);
                    ctx.closePath();
                    ctx.fillStyle = colors[key] || '#4a5e82';
                    ctx.fill();
                    angle += slice + gap;
                });
                ctx.beginPath(); ctx.arc(cx,cy,inner,0,Math.PI*2);
                ctx.fillStyle = '#111827'; ctx.fill();
                ctx.fillStyle = '#e8edf5';
                ctx.font = 'bold 22px "DM Sans"';
                ctx.textAlign = 'center'; ctx.textBaseline = 'middle';
                ctx.fillText(total, cx, cy);
            }

            function renderLegend(containerId, data, colors) {
                var el = document.getElementById(containerId);
                el.innerHTML = Object.entries(data).map(function (entry) {
                    var k = entry[0], v = entry[1];
                    return '<div class="legend-item">' +
                        '<div class="legend-dot" style="background:' + (colors[k] || '#4a5e82') + '"></div>' +
                        '<span>' + t('status.' + k, {}) + '</span>' +
                        '<span class="legend-val">' + v + '</span>' +
                        '</div>';
                }).join('');
            }

            function renderLegendPriority(containerId, data, colors) {
                var el = document.getElementById(containerId);
                el.innerHTML = Object.entries(data).map(function (entry) {
                    var k = entry[0], v = entry[1];
                    return '<div class="legend-item">' +
                        '<div class="legend-dot" style="background:' + (colors[k] || '#4a5e82') + '"></div>' +
                        '<span>' + t('priority.' + k) + '</span>' +
                        '<span class="legend-val">' + v + '</span>' +
                        '</div>';
                }).join('');
            }

            function renderAssigneeBar(data) {
                var el = document.getElementById('assigneeChart');
                var entries = Object.entries(data).sort(function (a,b) { return b[1] - a[1]; });
                if (!entries.length) {
                    el.innerHTML = '<div style="color:var(--text-muted);font-size:0.85rem">' + t('dashboard.no_data') + '</div>';
                    return;
                }
                var max = Math.max.apply(null, entries.map(function (e) { return e[1]; }));
                var barColors = ['#f59e0b','#6366f1','#10b981','#ef4444','#f97316','#8b5cf6'];
                el.innerHTML = entries.slice(0, 10).map(function (entry, i) {
                    var name = entry[0], count = entry[1];
                    return '<div class="bar-row">' +
                        '<div class="bar-label">' + Helpers.escapeHtml(name) + '</div>' +
                        '<div class="bar-track">' +
                            '<div class="bar-fill" style="width:' + (count/max*100) + '%;background:' + barColors[i % barColors.length] + '"></div>' +
                        '</div>' +
                        '<div class="bar-count">' + count + '</div>' +
                        '</div>';
                }).join('');
            }

            function animateCount(el, target) {
                var duration = 600, startTime = performance.now();
                var isDecimal = String(target).indexOf('.') !== -1;
                function update(now) {
                    var p = Math.min((now - startTime) / duration, 1);
                    var ease = 1 - Math.pow(1 - p, 3);
                    el.textContent = isDecimal ? (target * ease).toFixed(1) : Math.round(target * ease);
                    if (p < 1) requestAnimationFrame(update);
                }
                requestAnimationFrame(update);
            }

            function loadStats() {
                API.get('/api/tickets/stats')
                    .then(function (res) {
                        if (!res.ok) throw new Error(t('common.error'));
                        return res.json();
                    })
                    .then(function (stats) {
                        animateCount(document.getElementById('statTotal'),      stats.total);
                        animateCount(document.getElementById('statOpen'),       (stats.byStatus && stats.byStatus.Open)       || 0);
                        animateCount(document.getElementById('statInProgress'), (stats.byStatus && stats.byStatus.InProgress) || 0);
                        animateCount(document.getElementById('statResolved'),   ((stats.byStatus && stats.byStatus.Resolved)  || 0) +
                                                                                ((stats.byStatus && stats.byStatus.Closed)    || 0));
                        animateCount(document.getElementById('statAvg'),        stats.avgResolutionHours || 0);

                        drawDonut('statusChart', stats.byStatus || {}, STATUS_COLORS);
                        renderLegend('statusLegend', stats.byStatus || {}, STATUS_COLORS);
                        drawDonut('priorityChart', stats.byPriority || {}, PRIORITY_COLORS);
                        renderLegendPriority('priorityLegend', stats.byPriority || {}, PRIORITY_COLORS);
                        renderAssigneeBar(stats.byAssignee || {});
                    })
                    .catch(function (err) { Notifications.error(err.message); });
            }

            document.getElementById('refreshBtn').addEventListener('click', loadStats);
            document.addEventListener('tm:ticketCreated',  function () { loadStats(); });
            document.addEventListener('tm:ticketUpdated',  function () { loadStats(); });
            document.addEventListener('tm:statusChanged',  function () { loadStats(); });
            document.addEventListener('tm:langChanged',    function () { I18n.applyToPage(); loadStats(); });

            loadStats();
        });
    </script>
}